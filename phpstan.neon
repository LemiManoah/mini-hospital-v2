includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:

    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - public
        - routes

    excludePaths:
        analyse:
            - database/migrations/2026_03_06_091646_create_permission_tables.php

    level: max

    tmpDir: /tmp/phpstan
