{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel Server",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve"],
      "port": 8000
    },
    {
      "name": "Vite",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Queue Worker",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1"]
    },
    {
      "name": "Log Viewer (Pail)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "pail", "--timeout=0"]
    }
  ]
}
